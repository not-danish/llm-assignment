# Copy this file to .env and fill in values before running the app.

# OpenAI-compatible chat endpoint used in this project (Qwen gateway)
QWEN_API_BASE_URL=https://rsm-8430-finalproject.bjlkeng.io/v1

# Required for chat model calls in app.py
OPENAI_API_KEY=REPLACE_WITH_YOUR_KEY

# Optional alternate OpenAI-compatible base URL
OPENAI_BASE_URL=

# Optional model overrides used by notebooks
EMBEDDING_MODEL=text-embedding-3-small
CHAT_MODEL=qwen3-30b-a3b-fp8
LOCAL_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
